#!/bin/sh
set -e
case "$1" in
    configure)
        if getent group dhttp >/dev/null; then
            :
        else
            status=$?
            if [ "$status" -ne 2 ]; then
                exit "$status"
            fi
            addgroup --system --quiet dhttp
        fi
        install -d -m 0755 /etc/dhttp
        ;;
esac
#DEBHELPER#
exit 0

#!/usr/bin/make -f

# dpkg-buildpackage calls this via debian/rules.
# TRIPLE is passed as an environment variable by xtask (base triple, used for
# target/ output paths). ZIG_TARGET is the glibc-suffixed target passed to
# cargo-zigbuild (e.g. x86_64-unknown-linux-gnu.2.28). CARGO_FEATURES is
# optional.
#
# This file lives in xtask/deb/ and is copied into target/.../deb/src/debian/
# before dpkg-buildpackage runs. xtask points SOURCE_ROOT at the primary source
# bind mount inside the build container.

export DH_VERBOSE = 1
BUILD_PROFILE ?= release
CARGO_PROFILE_ARGS ?= --release
SOURCE_ROOT ?= /workspace

%:
	dh $@

# --- pishoo binary build (arch-any only) ---

# TODO: Remove this cargo-zigbuild workaround after rustc/Zig agree on the
# Cortex-A53 843419 mitigation linker argument.
override_dh_auto_build:
ifdef TRIPLE
	cd $(SOURCE_ROOT) && \
	export RUSTFLAGS="$${RUSTFLAGS:-} -L /usr/lib/$(DEB_HOST_MULTIARCH)" && \
	if [ "$(TRIPLE)" = "aarch64-unknown-linux-gnu" ]; then \
		{ \
			printf '%s\n' '#!/usr/bin/env bash'; \
			printf '%s\n' 'set -euo pipefail'; \
			printf '%s\n' 'if [ "$${1:-}" = "cc" ] || [ "$${1:-}" = "c++" ]; then'; \
			printf '%s\n' '    zig_subcommand="$$1"'; \
			printf '%s\n' '    shift'; \
			printf '%s\n' '    filtered_args=()'; \
			printf '%s\n' '    for arg in "$$@"; do'; \
			printf '%s\n' '        case "$$arg" in'; \
			printf '%s\n' '            -Wl,--fix-cortex-a53-843419|--fix-cortex-a53-843419)'; \
			printf '%s\n' '                continue'; \
			printf '%s\n' '                ;;'; \
			printf '%s\n' '        esac'; \
			printf '%s\n' '        filtered_args+=("$$arg")'; \
			printf '%s\n' '    done'; \
			printf '%s\n' '    exec /usr/local/zig/zig "$$zig_subcommand" "$${filtered_args[@]}"'; \
			printf '%s\n' 'fi'; \
			printf '%s\n' 'exec /usr/local/zig/zig "$$@"'; \
		} > /tmp/pishoo-aarch64-zig; \
		chmod +x /tmp/pishoo-aarch64-zig; \
		export CARGO_ZIGBUILD_ZIG_PATH=/tmp/pishoo-aarch64-zig; \
		export RUSTFLAGS="$$RUSTFLAGS -Z unstable-options -Clinker-flavor=gnu-lld-cc"; \
	fi && \
	$(if $(PISHOO_WORKER_BIN),export PISHOO_WORKER_BIN=$(PISHOO_WORKER_BIN) &&) \
	$(if $(PISHOO_SSH_SESSION_BIN),export PISHOO_SSH_SESSION_BIN=$(PISHOO_SSH_SESSION_BIN) &&) \
	cargo zigbuild $(CARGO_PROFILE_ARGS) --manifest-path pishoo/Cargo.toml --target $(ZIG_TARGET)$(if $(CARGO_FEATURES), --features $(CARGO_FEATURES))
endif

override_dh_auto_install:
ifdef TRIPLE
	mkdir -p debian/pishoo/usr/bin
	cp $(SOURCE_ROOT)/target/$(TRIPLE)/$(BUILD_PROFILE)/pishoo debian/pishoo/usr/bin/
	chmod 755 debian/pishoo/usr/bin/pishoo
	mkdir -p debian/pishoo/usr/libexec/pishoo
	cp $(SOURCE_ROOT)/target/$(TRIPLE)/$(BUILD_PROFILE)/pishoo-worker debian/pishoo/usr/libexec/pishoo/
	chmod 755 debian/pishoo/usr/libexec/pishoo/pishoo-worker
ifdef PISHOO_SSH_SESSION_BIN
	cp $(SOURCE_ROOT)/target/$(TRIPLE)/$(BUILD_PROFILE)/pishoo-ssh-session debian/pishoo/usr/libexec/pishoo/
	chmod 755 debian/pishoo/usr/libexec/pishoo/pishoo-ssh-session
endif
endif
	# pishoo-common: install config files
	mkdir -p debian/pishoo-common
	cp -r debian/common/* debian/pishoo-common/

override_dh_auto_test:
	# skip tests in cross-compilation environment

override_dh_installsystemd:
	dh_installsystemd --name=pishoo

override_dh_strip:
	# skip: cross-compiled binaries cannot be stripped by host strip

override_dh_makeshlibs:
	# skip: package does not ship shared libraries

override_dh_shlibdeps:
ifdef TRIPLE
	dh_shlibdeps -ppishoo -l/usr/lib/$(DEB_HOST_MULTIARCH)
endif

override_dh_auto_clean:
	# do not run cargo clean; workspace is bind-mounted

    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'gateway'",
            "cargo": {
                "args": ["build", "--bin=gateway", "--package=gateway"],
                "filter": {
                    "name": "gateway",
                    "kind": "bin"
                }
            },
            "args": ["config/reverse.conf"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'gateway'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=gateway",
                    "--package=gateway"
                ],
                "filter": {
                    "name": "gateway",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug example 'pishoo'",
            "cargo": {
                "args": [
                    "build",
                    "--example=pishoo",
                ],
                "filter": {
                    "name": "pishoo",
                    "kind": "example"
                }
            },
            "args": [
                "-c",
                "${workspaceFolder}/examples/pishoo.conf",
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}
